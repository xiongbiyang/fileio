# Cloudflare TURN (for WebRTC NAT traversal fallback)
NUXT_CLOUDFLARE_TURN_KEY_ID=
NUXT_CLOUDFLARE_TURN_API_TOKEN=

NUXT_PUBLIC_SITE_URL=https://fileio.top
NUXT_PUBLIC_PARTYKIT_HOST=

# Quick Share — Cloudflare Turnstile (human verification on upload)
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# For local dev you may use Cloudflare's always-pass test keys:
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=
