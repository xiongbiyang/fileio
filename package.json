{
  "name": "toolport",
  "version": "0.1.0",
  "private": true,
  "description": "ToolPort - Simple tools, done right.",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:party": "partykit dev",
    "dev:all": "concurrently \"npm run dev:party\" \"npm run dev\"",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "party:deploy": "partykit deploy",
    "lint": "eslint . --ignore-pattern .nuxt --ignore-pattern .nuxt-build* --ignore-pattern .output --ignore-pattern dist",
    "lint:i18n": "python scripts/check_i18n.py",
    "test": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^9.1.0",
    "@nuxtjs/sitemap": "^8.0.11",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vueuse/core": "^12.0.0",
    "jsqr": "^1.4.0",
    "marked": "^17.0.5",
    "nuxt": "^3.15.0",
    "partysocket": "^1.1.16",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.19",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.0",
    "@playwright/test": "^1.59.1",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^9.2.1",
    "partykit": "^0.0.115",
    "sass": "^1.82.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
